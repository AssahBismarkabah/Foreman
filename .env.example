# Foreman Environment Configuration
# Copy to .env and customize

# --- PostgreSQL ---
# Default credentials for the dev database
FOREMAN_PG_USER=foreman
FOREMAN_PG_PASSWORD=foreman
FOREMAN_PG_DATABASE=foreman
FOREMAN_PG_PORT=5432

# Test database (used by integration tests)
FOREMAN_TEST_DATABASE_URL=postgres://foreman:foreman@localhost:5432/foreman_test?sslmode=disable

# Production DSN (override in production deployments)
# FOREMAN_PG_DSN=postgres://foreman:mysecret@db.example.com:5432/foreman?sslmode=require

# Pool configuration
FOREMAN_PG_MAX_CONNS=25
FOREMAN_PG_MIN_CONNS=5

# --- NATS ---
FOREMAN_NATS_PORT=4222
FOREMAN_NATS_CLUSTER_PORT=6222
FOREMAN_NATS_HTTP_PORT=8222

# --- Identity / Signing Key ---
# The signing key is a PEM-encoded RSA private key used to sign agent JWTs.
# Generate one with: openssl genrsa 2048 | base64
# FOREMAN_SIGNING_KEY=<base64-encoded-pem>

# --- Foreman ---
FOREMAN_CONFIG_PATH=foreman.yaml
